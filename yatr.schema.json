{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config",
  "description": "Root configuration structure",
  "type": "object",
  "properties": {
    "env": {
      "description": "Global environment variables",
      "default": {},
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "include": {
      "description": "Other yatr.toml files to merge in (paths relative to this file). Their tasks and env are composed into this config; their settings are ignored (the root file's settings are authoritative).",
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "settings": {
      "description": "Global settings",
      "default": {
        "cache": false,
        "cache_dir": null,
        "parallelism": 0,
        "remote_cache": null,
        "shell": null,
        "watch_debounce_ms": 0
      },
      "allOf": [
        {
          "$ref": "#/definitions/Settings"
        }
      ]
    },
    "tasks": {
      "description": "Task definitions",
      "default": {},
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/TaskConfig"
      }
    },
    "toolchain": {
      "description": "Pinned language toolchains, auto-downloaded and put on task `PATH`.",
      "default": {},
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/ToolchainConfig"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "CacheProtocol": {
      "description": "Remote cache wire protocol.",
      "oneOf": [
        {
          "description": "yatr's own JSON action results + BLAKE3 blobs (default).",
          "type": "string",
          "enum": [
            "native"
          ]
        },
        {
          "description": "Bazel Remote Execution API: SHA-256 digests + protobuf `ActionResult`.",
          "type": "string",
          "enum": [
            "reapi"
          ]
        }
      ]
    },
    "RemoteCacheConfig": {
      "description": "Configuration for a shared HTTP remote cache.\n\nThe cache speaks a simple REST protocol — `GET`/`PUT`/`HEAD` on `<url>/ac/<key>` (action results) and `<url>/cas/<blob>` (content blobs) — so it works against a plain object store or a small server, and shares the path layout used by Bazel's HTTP cache.",
      "type": "object",
      "required": [
        "url"
      ],
      "properties": {
        "protocol": {
          "description": "Wire protocol: `native` (yatr's JSON + BLAKE3) or `reapi` (SHA-256 + protobuf `ActionResult`, compatible with bazel-remote / BuildBuddy).",
          "default": "native",
          "allOf": [
            {
              "$ref": "#/definitions/CacheProtocol"
            }
          ]
        },
        "read": {
          "description": "Read from the remote cache on a local miss",
          "default": true,
          "type": "boolean"
        },
        "sign_key_env": {
          "description": "Name of the environment variable holding a shared secret used to sign and verify cached action results (keyed BLAKE3 MAC). When set, entries that fail verification are rejected — protection against cache poisoning.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "token_env": {
          "description": "Name of the environment variable holding a bearer token, if auth is required. Keeps secrets out of the committed config file.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "description": "Base URL of the remote cache (e.g. `https://cache.example.com/yatr`)",
          "type": "string"
        },
        "write": {
          "description": "Write to the remote cache after a successful run",
          "default": true,
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "Settings": {
      "description": "Global settings for YATR behavior",
      "type": "object",
      "properties": {
        "cache": {
          "description": "Enable caching by default",
          "default": true,
          "type": "boolean"
        },
        "cache_dir": {
          "description": "Cache directory (defaults to .yatr/cache)",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "parallelism": {
          "description": "Default parallelism level (0 = number of CPUs)",
          "default": 0,
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "remote_cache": {
          "description": "Optional shared/remote cache backend",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RemoteCacheConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "shell": {
          "description": "Default shell to use (if shell mode enabled)",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "watch_debounce_ms": {
          "description": "Watch debounce delay in milliseconds",
          "default": 300,
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "TaskConfig": {
      "description": "Configuration for a single task",
      "type": "object",
      "properties": {
        "allow_failure": {
          "description": "Continue even if this task fails",
          "default": false,
          "type": "boolean"
        },
        "cwd": {
          "description": "Working directory for this task",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "depends": {
          "description": "Tasks that must complete before this one",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "desc": {
          "description": "Human-readable description",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "env": {
          "description": "Task-specific environment variables",
          "default": {},
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "foreground": {
          "description": "Run in foreground with inherited stdio (for long-running processes like dev servers)",
          "default": false,
          "type": "boolean"
        },
        "no_cache": {
          "description": "Skip caching for this task",
          "default": false,
          "type": "boolean"
        },
        "outputs": {
          "description": "Output files/directories produced by this task",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parallel": {
          "description": "Run commands in parallel",
          "default": false,
          "type": "boolean"
        },
        "run": {
          "description": "Commands to run (simple string list mode)",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "script": {
          "description": "Rhai script to execute (alternative to `run`)",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "shell": {
          "description": "Use shell to execute commands",
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "sources": {
          "description": "Files that affect the cache key (glob patterns)",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeout": {
          "description": "Timeout in seconds",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "wasm": {
          "description": "WASM plugin to run for this task (alternative to `run`/`script`). Path is relative to the task's working directory.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "watch": {
          "description": "Files to watch for this task (glob patterns)",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "ToolchainConfig": {
      "description": "A pinned, auto-downloaded language toolchain.\n\nThe `url` (and optional `bin`) are templates where `{version}`, `{os}`, and `{arch}` are substituted. `{os}` is `linux`/`darwin`/`win`; `{arch}` is `x64`/`arm64` (matching the common Node-style naming).",
      "type": "object",
      "required": [
        "url",
        "version"
      ],
      "properties": {
        "bin": {
          "description": "Subdirectory within the extracted archive to add to `PATH` (template; defaults to the archive root).",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "description": "Download URL template for the archive (currently `.tar.gz`/`.tgz`).",
          "type": "string"
        },
        "version": {
          "description": "Version to install (substituted for `{version}`).",
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
